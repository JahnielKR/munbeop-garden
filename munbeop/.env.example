# Public — exposed to the client bundle via runtimeConfig.public
NUXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>

# Public — used by useAuth() to build the magic-link redirect URL
NUXT_PUBLIC_APP_URL=http://localhost:3000

# Private — server-only (used by future SSR auth plugin and CLI migrations)
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>
