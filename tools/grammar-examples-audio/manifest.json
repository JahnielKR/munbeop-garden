  { "id": "079b4aea", "sentence": "제가 사장이라면 직원들에게 휴가를 더 많이 줄 거예요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "96cc6cbc", "sentence": "친구가 저한테 시험이 많이 어렵냐고 했어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "11f425a7", "sentence": "동생이 언제 집에 오냐고 물었어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "d490a8da", "sentence": "이번 시험은 생각보다 어려울 듯해요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "d4b42037", "sentence": "그는 모든 걸 다 아는 듯이 고개를 끄덕였어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "9463bed6", "sentence": "한 가정의 가장으로서 저는 가족의 생계를 책임지고 있습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "5dbd6fe8", "sentence": "꾸준한 운동으로써 건강을 지킬 수 있어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "7b3e97c6", "sentence": "이렇게 비싼 약은 먹어 봤자 효과도 없어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "de435e9f", "sentence": "이미 다 끝난 일인데 후회해 봐야 소용없어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "cb012015", "sentence": "고민만 하지 말고 일단 지원하고 봐요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "7060ed93", "sentence": "급하게 짐을 싸고 보니까 여권을 안 챙겼더라고요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "8e6250e5", "sentence": "이번 주말에 부산으로 이사 가신다면서요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "3141d72f", "sentence": "너 다음 달에 군대 간다며?", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "0242b9aa", "sentence": "저는 이 일이 생각보다 어렵다고 생각해요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "17870905", "sentence": "이번 겨울이 유난히 춥다고 들었어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "cd249227", "sentence": "요즘 들어 시간이 정말 빠르다고 느껴요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "010b3539", "sentence": "불이 다 꺼진 걸 보니 가족들이 벌써 잠든 듯해요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "2c0a6a0e", "sentence": "그 식당은 평일인데도 줄이 긴 걸 보면 꽤 유명한 듯싶어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "747b49cf", "sentence": "친구가 약속을 잊었다고 할까 봐 미리 문자를 보냈어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "dc5f18c6", "sentence": "네가 또 바쁘다고 할 줄 알았어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "8c234491", "sentence": "내일 비가 많이 온다는데 우산 챙기는 게 좋겠어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "b4b0ccaf", "sentence": "그 영화 진짜 무섭다더라, 혼자 보지 마.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "231b4763", "sentence": "오늘 하루 종일 안 바쁘다더니 왜 이렇게 연락이 안 됐어?", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "ff308c11", "sentence": "다음 주 월요일에 본사로 회장님을 직접 찾아 뵙겠습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "6c6f1413", "sentence": "부장님, 그럼 회의 끝나고 로비에서 봬요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "5f1b4a92", "sentence": "할머니는 시골에서 작은 텃밭을 가꾸며 사세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "2ad79d05", "sentence": "요즘은 매일 운동하며 건강하게 지내고 있어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "4ab56fc5", "sentence": "비가 흠뻑 내리면 메마른 논밭에 더없이 좋으련마는 하늘은 야속하게도 구름 한 점 내주지 않는구나.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "50c1baec", "sentence": "벗이 곁에 있다면 이 먼 길도 함께 가련만 홀로 떠나는 나그네의 발걸음이 한없이 무겁기만 하구나.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "df60b0b2", "sentence": "듣건대, 그 고을의 백성들이 오랜 가뭄으로 큰 고초를 겪고 있다 하더이다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "c39c27f6", "sentence": "생각건대, 나라의 흥망은 결국 백성의 마음을 얻느냐 잃느냐에 달려 있는 것이다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "871d7608", "sentence": "바라건대, 이 땅에 다시는 그와 같은 비극이 되풀이되지 않기를.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "1467f5a3", "sentence": "아, 이 강산이 천하의 절경이로구나… 참으로 빼어난 경치로다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "5f7242bb", "sentence": "오랜 세월을 견뎌 온 이 한 그루 소나무야말로 이 산의 주인이로다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "9a89fea6", "sentence": "주말에 친구를 만나요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "34041471", "sentence": "책상 위에 안경이 있어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "26b1b89b", "sentence": "주말에 친구들하고 공원에서 자전거를 탔어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "da6b2c8c", "sentence": "이 사과는 시골에서 왔어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "e6350671", "sentence": "오늘은 비도 오고 바람도 불어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "cd1100ab", "sentence": "나도 그 영화 봤어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "3d49d76b", "sentence": "나는 너만 믿어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "6c30c0c7", "sentence": "주말에는 집에서만 쉬었어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "d42b6018", "sentence": "이것은 우리 회사의 새 제품입니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "9947cdcf", "sentence": "어제 엄마의 생일이라서 케이크를 샀어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "b8ca492f", "sentence": "이 글자는 빨간색 펜으로 써.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "dfbb0170", "sentence": "사거리에서 오른쪽으로 가시면 됩니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "d668ed36", "sentence": "버스가 십 분마다 와요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "be5ba503", "sentence": "주말마다 할머니 댁에 갑니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "b64b7185", "sentence": "주말에 영화나 볼까?", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "7f2f7e13", "sentence": "시간이 있으면 책이나 좀 읽으세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "36548626", "sentence": "내일은 비가 오겠어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "2e96fe74", "sentence": "제가 이 짐을 들어 드리겠습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "66d30163", "sentence": "날씨도 좋은데 커피 한 잔 마실래요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "383e601b", "sentence": "피곤하면 먼저 집에 갈래?", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "32c4b4c6", "sentence": "밖에 눈이 많이 왔네요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "47171069", "sentence": "어, 벌써 시간이 이렇게 됐네!", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "952d17db", "sentence": "오늘 날씨가 정말 춥죠?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "9bba754b", "sentence": "회의가 세 시에 시작하지요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "9857fa3f", "sentence": "오늘은 일이 별로 없으니까 좀 일찍 가도 돼요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "e55caf53", "sentence": "엄마, 이 과자 다 먹어도 돼?", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "0be0326e", "sentence": "내일은 일요일이라서 일찍 일어나지 않아도 돼요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "72950e66", "sentence": "내가 이미 다 해 놨으니까 너는 도와주지 않아도 돼.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "65769949", "sentence": "할머니, 제가 짐을 들어 드릴게요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "75144324", "sentence": "손님, 선물이니까 예쁘게 포장해 드리겠습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "540f90d2", "sentence": "수업 시간에 휴대폰 보지 마세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "83eca90d", "sentence": "내일 비 온대, 우산 가져오는 거 잊지 마.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "2df9ef05", "sentence": "이거 말고 저거 보여 주세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "e02fa6d9", "sentence": "내일 말고 모레 만나자.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "7a97e6d2", "sentence": "운전할 때는 휴대폰을 보면 안 됩니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "f31a7158", "sentence": "어렸을 때 시골에서 할머니랑 살았어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "aab0d21d", "sentence": "회사에 가기 전에 커피를 한 잔 마셔요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "0641bd78", "sentence": "밥을 먹기 전에 손을 깨끗이 씻어라.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "22b2b1ac", "sentence": "제가 회의하는 동안 아이를 좀 봐 주시겠어요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "331affc2", "sentence": "비가 오는 동안 우리는 카페에서 기다렸어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "68c6cca9", "sentence": "운동하는 것이 건강에 정말 좋아요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "bdf3927c", "sentence": "혼자 영화 보는 거 별로 안 좋아해.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "bdbaf60c", "sentence": "민수 씨는 벌써 집에 간 것 같아요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "971741ff", "sentence": "밖에 비가 오는 것 같아.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "690f54b0", "sentence": "표가 매진됐네요. 이 영화가 인기가 많은 모양이에요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "1487543f", "sentence": "옆집 형은 요즘 매일 도서관에 가던데, 시험이 곧 있는 모양이야.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "67bca6c6", "sentence": "이 약은 하루에 세 번 식사 후에 먹으면 됩니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "66b4f843", "sentence": "걱정하지 마, 늦으면 그냥 나한테 전화하면 돼.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "810cf009", "sentence": "수업 시간에 휴대폰을 보면 안 됩니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "32e836af", "sentence": "이건 비밀이니까 누구한테도 말하면 안 돼.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "32bc4e30", "sentence": "내일 아침에 일찍 전화할게요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "de0d571b", "sentence": "설거지는 내가 할게.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "53e9f6f9", "sentence": "창문을 좀 열까요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "84e8d33c", "sentence": "내일 날씨가 좋을까요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "6fdb3e8b", "sentence": "버스를 놓치지 않으려고 아침 일찍 집을 나섰어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "4dff6829", "sentence": "건강을 지키려고 매일 아침 공원에서 운동합니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "d99b6c8d", "sentence": "제주도에 한번 가 보세요. 정말 좋아요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "13319b6a", "sentence": "이 신발 한번 신어 봐도 돼요?", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "0c2947db", "sentence": "창문 좀 열어 주세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "d1e40f9e", "sentence": "친구가 무거운 가방을 들어 줬어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "a62eecc5", "sentence": "버스가 눈앞에서 그냥 가 버렸어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "8fc22a72", "sentence": "배가 너무 고파서 케이크를 혼자 다 먹어 버렸어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "5f5b8179", "sentence": "지금 길이 많이 막히니까 우리 지하철로 가자.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "9d1c887d", "sentence": "처음 오셨으니까 제가 사무실을 안내해 드리겠습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "59aebaa7", "sentence": "심심할 때는 게임을 하거나 친구한테 전화해.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "fbe44ba2", "sentence": "면접에 늦거나 결석하면 합격하기 어렵습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "06d29cc3", "sentence": "동생이 저보다 키가 더 커요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "bbf60644", "sentence": "오늘은 어제보다 훨씬 추워.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "26fb8345", "sentence": "내일 비가 올지 안 올지 잘 모르겠어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "3882466b", "sentence": "이 영화가 왜 그렇게 인기가 많은지 모르겠다.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "7ec8de6b", "sentence": "지금 밖에 비가 오는데요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "407cd116", "sentence": "저는 매운 거 잘 못 먹는데요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "e278b97a", "sentence": "이 영화가 얼마나 재미있는지 몰라. 너도 꼭 봐.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "45e889e6", "sentence": "어제 하루 종일 얼마나 많이 걸었는지 다리가 너무 아파요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "f7894b7e", "sentence": "이번 사고에 대해서 자세히 설명해 주시겠습니까?", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "66ed5fbe", "sentence": "나 그 영화에 대해 아무것도 몰라.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "12a8ee6a", "sentence": "친구가 화났을까 봐 계속 연락했어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "feaa0589", "sentence": "늦을까 봐 택시를 탔어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "d78ee47a", "sentence": "아무리 바쁘더라도 가족과 보내는 시간은 꼭 챙기세요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "beb825a1", "sentence": "내일 비가 오더라도 우리는 예정대로 등산을 갈 거야.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "af1f7801", "sentence": "지금 출발 안 하면 기차를 놓칠지도 몰라요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "a7f2be6a", "sentence": "민수는 아직 그 소식을 모를지도 몰라.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "ec1b6762", "sentence": "내일 시험 있잖아요, 오늘은 일찍 자야겠어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
