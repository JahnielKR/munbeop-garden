  { "id": "f15df843", "sentence": "오랜만에 고향에 갔더니 동네가 정말 많이 변했더라고요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "0175c38d", "sentence": "어제 새로 산 신발을 신어 봤는데 생각보다 좀 작더라고요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "f46b8e0e", "sentence": "어제는 다리가 후들거릴 만큼 오래 걸었어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
  { "id": "8a3522d9", "sentence": "그 영화는 두 번 봐도 안 질릴 만큼 재미있어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "4482e0c2", "sentence": "시간 없으면 라면이라도 끓여 먹어.", "level": "casual", "voice": "ko-KR-SunHiNeural", "rate": "+6%", "pitch": "+16Hz" },
  { "id": "f2041861", "sentence": "잠깐이라도 쉬셨으면 좋겠습니다.", "level": "formal", "voice": "ko-KR-InJoonNeural", "rate": "-4%", "pitch": "-3Hz" },
  { "id": "c41f2f3f", "sentence": "우리 딸이 벌써 대학생이 되었어요.", "level": "polite", "voice": "ko-KR-SunHiNeural", "rate": "+0%", "pitch": "+4Hz" },
